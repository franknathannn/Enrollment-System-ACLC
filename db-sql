  first_name text NOT NULL,
  last_name text NOT NULL,
  middle_name text,
  gender USER-DEFINED NOT NULL,
  strand USER-DEFINED NOT NULL,
  contact_no character varying,
  email text,
  gwa_grade_10 numeric DEFAULT 0,
  profile_picture text,
  status USER-DEFINED DEFAULT 'Pending'::enrollment_status,
  decline_reason text,
  guardian_name text,
  guardian_contact character varying,
  section_id uuid,
  school_year character varying NOT NULL,
  form_138_url text,
  good_moral_url text,
  created_at timestamp with time zone DEFAULT now(),
  cor_url text,
  af5_url text,
  diploma_url text,
  age integer,
  civil_status text,
  last_school_attended text,
  guardian_first_name text,
  guardian_middle_name text,
  guardian_last_name text,
  student_category text,
  two_by_two_url text,
