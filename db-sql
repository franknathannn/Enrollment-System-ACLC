);
CREATE TABLE public.system_config (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  enrollment_start date,
  enrollment_end date,
  school_year text DEFAULT '2025-2026'::text,
  capacity integer DEFAULT 1000 CHECK (capacity >= 1),
  is_portal_active boolean DEFAULT true,
  updated_at timestamp with time zone DEFAULT now(),
  control_mode text DEFAULT 'automatic'::text,
  voucher_value integer DEFAULT 22500,
  field_requirements jsonb,
  is_pre_enrollment boolean DEFAULT false,
  CONSTRAINT system_config_pkey PRIMARY KEY (id)
);
CREATE TABLE public.system_settings (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  setting_key text NOT NULL UNIQUE,
  value_bool boolean DEFAULT true,
  updated_at timestamp with time zone DEFAULT timezone('utc'::text, now()),
  value_text text,
  value_int integer DEFAULT 1000,
  CONSTRAINT system_settings_pkey PRIMARY KEY (id)
);
CREATE TABLE public.teacher_announcements (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  title text NOT NULL,
  body text NOT NULL,
  posted_by text NOT NULL DEFAULT 'Admin'::text,
  target text NOT NULL DEFAULT 'ALL'::text,
  is_pinned boolean NOT NULL DEFAULT false,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT teacher_announcements_pkey PRIMARY KEY (id)
);
CREATE TABLE public.teachers (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  full_name text NOT NULL,
  email text NOT NULL UNIQUE,
  password_hash text NOT NULL,
  phone text,
  subject_specialization text,
  avatar_url text,
  is_active boolean NOT NULL DEFAULT true,
  school_year character varying NOT NULL DEFAULT '2025-2026'::character varying,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  CONSTRAINT teachers_pkey PRIMARY KEY (id)
);