CREATE TABLE public.activity_logs (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  created_at timestamp with time zone DEFAULT now(),
  admin_id uuid,
  action_type text NOT NULL,
  student_name text NOT NULL,
  details text,
  admin_name text,
  student_image text,
  student_id uuid,
  CONSTRAINT activity_logs_pkey PRIMARY KEY (id),
  CONSTRAINT activity_logs_admin_id_fkey FOREIGN KEY (admin_id) REFERENCES auth.users(id),
  CONSTRAINT activity_logs_student_id_fkey FOREIGN KEY (student_id) REFERENCES public.students(id)
);
CREATE TABLE public.admin_messages (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  sender_id uuid NOT NULL,
  content text NOT NULL,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT admin_messages_pkey PRIMARY KEY (id),
  CONSTRAINT admin_messages_sender_id_fkey FOREIGN KEY (sender_id) REFERENCES public.admin_profiles(id)
);
CREATE TABLE public.admin_profiles (
  id uuid NOT NULL,
  full_name text,
  avatar_url text,
  updated_at timestamp with time zone DEFAULT now(),
  CONSTRAINT admin_profiles_pkey PRIMARY KEY (id),
  CONSTRAINT admin_profiles_id_fkey FOREIGN KEY (id) REFERENCES auth.users(id)
);
CREATE TABLE public.attendance (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  student_id uuid NOT NULL,
  lrn character varying NOT NULL,
  student_name text NOT NULL,
  section text NOT NULL,
  strand text NOT NULL,
  subject text NOT NULL,
  date date NOT NULL DEFAULT CURRENT_DATE,
  time time without time zone NOT NULL DEFAULT CURRENT_TIME,
  status USER-DEFINED NOT NULL DEFAULT 'Present'::attendance_status,
  school_year character varying NOT NULL,
  notes text,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  CONSTRAINT attendance_pkey PRIMARY KEY (id),
  CONSTRAINT attendance_student_id_fkey FOREIGN KEY (student_id) REFERENCES public.students(id)
);
CREATE TABLE public.attendance_excuses (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  student_id uuid NOT NULL,
  attendance_date date NOT NULL,
  subject text,
  reason text NOT NULL,
  excused_by uuid,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT attendance_excuses_pkey PRIMARY KEY (id),
  CONSTRAINT attendance_excuses_excused_by_fkey FOREIGN KEY (excused_by) REFERENCES public.teachers(id),
  CONSTRAINT attendance_excuses_student_id_fkey FOREIGN KEY (student_id) REFERENCES public.students(id)
);
CREATE TABLE public.class_suspensions (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  teacher_id uuid NOT NULL,
  section text NOT NULL,
  subject text,
  suspension_date date NOT NULL,
  reason text NOT NULL,
  school_year character varying NOT NULL DEFAULT '2025-2026'::character varying,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT class_suspensions_pkey PRIMARY KEY (id),
  CONSTRAINT class_suspensions_teacher_id_fkey FOREIGN KEY (teacher_id) REFERENCES public.teachers(id)
);
CREATE TABLE public.edit_requests (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  student_id uuid NOT NULL,
  reason text NOT NULL,
  status text NOT NULL DEFAULT 'Pending'::text CHECK (status = ANY (ARRAY['Pending'::text, 'Approved'::text, 'Rejected'::text])),
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  CONSTRAINT edit_requests_pkey PRIMARY KEY (id),
  CONSTRAINT edit_requests_student_id_fkey FOREIGN KEY (student_id) REFERENCES public.students(id)
);
CREATE TABLE public.enrollment_history (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  school_year text NOT NULL UNIQUE,
  male_total integer DEFAULT 0,
  female_total integer DEFAULT 0,
  recorded_at timestamp with time zone DEFAULT now(),
  total_combined bigint DEFAULT 0,
  CONSTRAINT enrollment_history_pkey PRIMARY KEY (id)
);
CREATE TABLE public.enrollment_predictions_data (
  id uuid NOT NULL,
  school_year text,
  total_enrolled integer,
  jhs_graduates_count integer,
  created_at timestamp without time zone,
  als_passers_count integer,
  others_count integer DEFAULT 0,
  CONSTRAINT enrollment_predictions_data_pkey PRIMARY KEY (id)
);
CREATE TABLE public.message_reads (
  message_id uuid NOT NULL,
  user_id uuid NOT NULL,
  read_at timestamp with time zone DEFAULT now(),
  CONSTRAINT message_reads_pkey PRIMARY KEY (message_id, user_id),
  CONSTRAINT message_reads_message_id_fkey FOREIGN KEY (message_id) REFERENCES public.admin_messages(id),
  CONSTRAINT message_reads_user_id_fkey FOREIGN KEY (user_id) REFERENCES public.admin_profiles(id)
);
CREATE TABLE public.schedules (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  section text NOT NULL,
  subject text NOT NULL,
  day text NOT NULL,
  start_time time without time zone NOT NULL,
  end_time time without time zone NOT NULL,
  school_year character varying NOT NULL DEFAULT '2025-2026'::character varying,
  created_at timestamp with time zone DEFAULT now(),
  teacher text,
  room text,
  notes text,
  teacher_id uuid,
  CONSTRAINT schedules_pkey PRIMARY KEY (id),
  CONSTRAINT schedules_teacher_id_fkey FOREIGN KEY (teacher_id) REFERENCES public.teachers(id)
);
CREATE TABLE public.school_calendar_events (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  title text NOT NULL,
  description text,
  event_date date NOT NULL,
  end_date date,
  event_type text NOT NULL DEFAULT 'event'::text CHECK (event_type = ANY (ARRAY['holiday'::text, 'event'::text, 'meeting'::text, 'exam'::text, 'suspension'::text])),
  school_year text NOT NULL DEFAULT '2025-2026'::text,
  color text DEFAULT '#3b82f6'::text,
  is_all_day boolean DEFAULT true,
  created_by uuid,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  CONSTRAINT school_calendar_events_pkey PRIMARY KEY (id),
  CONSTRAINT school_calendar_events_created_by_fkey FOREIGN KEY (created_by) REFERENCES auth.users(id)
);
CREATE TABLE public.sections (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  section_name text NOT NULL UNIQUE,
  strand USER-DEFINED NOT NULL,
  capacity integer DEFAULT 40,
  male_count integer DEFAULT 0,
  female_count integer DEFAULT 0,
  created_at timestamp with time zone DEFAULT now(),
  grade_level text NOT NULL DEFAULT '11'::text CHECK (grade_level = ANY (ARRAY['11'::text, '12'::text])),
  CONSTRAINT sections_pkey PRIMARY KEY (id)
);
